# SiteGuard 环境配置
# 复制此文件为 .env 并根据需要修改

# 服务器
SITEGUARD_BASE_DIR=
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# 路径
MODELS_DIR=data/models
DATA_DIR=data/raw
STATIC_DIR=apps/server/static
EXPORTS_DIR=apps/server/exports

# AI 配置
DEFAULT_MODEL=yolo26n_ppe.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.5
MAX_DETECTIONS=300
